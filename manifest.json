{
  "manifest_version": 3,
  "name": "Remember - 사이트 보관함",
  "version": "1.0.0",
  "description": "웹 페이지와 확장프로그램에서 북마크를 동일 UI로 관리하고 Google Drive로 동기화합니다.",
  "permissions": ["identity", "tabs", "storage", "alarms", "contextMenus"],
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*"
  ],
  "icons": {
    "16": "icons/favicon-16x16.png",
    "32": "icons/favicon-32x32.png",
    "48": "icons/android-chrome-192x192.png",
    "128": "icons/android-chrome-512x512.png"
  },
  "action": {
    "default_title": "Remember",
    "default_icon": {
      "16": "icons/favicon-16x16.png",
      "32": "icons/favicon-32x32.png"
    },
    "default_popup": "extension/popup.html"
  },
  "commands": {
    "save-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "현재 활성 탭을 Remember에 저장"
    }
  },
  "background": {
    "service_worker": "extension/background.js"
  }
}
